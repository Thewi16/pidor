#include <iostream>
#include <cmath>
#include <iomanip>

int main()
{
    std::cout << std::fixed << std::setprecision(2);
    
    double x_left = -12.0;
    double x_right = 12.0;
    double y_top = 12.0;
    
    double width = x_right - x_left;
    double S_rectangle = width * y_top;
    
    double S_under_abs = y_top * y_top;
    
    double S_shaded = S_rectangle - S_under_abs;
    
    std::cout << "Задача: найти площадь фигуры, ограниченной y = 12 и y = |x|" << std::endl;
    std::cout << "--------------------------------------------------------" << std::endl;
    std::cout << "Точки пересечения: x = " << x_left << " и x = " << x_right << std::endl;
    std::cout << "Ширина прямоугольника: " << width << std::endl;
    std::cout << "Высота прямоугольника: " << y_top << std::endl;
    std::cout << "Площадь прямоугольника: " << S_rectangle << std::endl;
    std::cout << "Площадь под |x| (интеграл от -12 до 12): " << S_under_abs << std::endl;
    std::cout << "--------------------------------------------------------" << std::endl;
    std::cout << "Площадь заштрихованной фигуры = " << S_shaded << std::endl;
    
    double triangle_area = (x_right * y_top) / 2.0;
    std::cout << "\nПроверка: фигура состоит из 2 треугольников" << std::endl;
    std::cout << "Площадь одного треугольника (12*12/2) = " << triangle_area << std::endl;
    std::cout << "Два треугольника дают: " << triangle_area * 2.0 << std::endl;
    
    return 0;
}
