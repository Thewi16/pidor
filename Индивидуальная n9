#include <iostream>
#include <cmath>
#include <iomanip>

using namespace std;

double f(double x) {
    return 12.0 - fabs(x);
}

int main() {
    cout << fixed << setprecision(10);
    cout << "Задача: найти площадь фигуры между y = |x| и y = 12\n\n";
    
    // Точки пересечения: |x| = 12 → x = -12 и x = 12
    // Площадь = 2 * ∫[0..12] (12 - x) dx = 2 * (12x - x²/2)|[0..12] = 2 * (144 - 72) = 144
    double analytic = 144.0;
    cout << "1. Аналитически: S = 144\n";
    
    int n = 1000000;
    double a = -12.0, b = 12.0;
    double h = (b - a) / n;
    double sum = 0.0;
    
    for (int i = 0; i < n; i++) {
        double x = a + (i + 0.5) * h;
        sum += f(x);
    }
    
    double numeric = sum * h;
    cout << "2. Численно (прямоугольники): S = " << numeric << "\n";
    
    // 3. Проверка через геометрию (треугольник)
    double base = 24.0;
    double height = 12.0;
    double geometric = 0.5 * base * height;
    cout << "3. Геометрически (треугольник): S = " << geometric << "\n";
    
    // 4. Вычисление через интеграл от 0 до 12 с удвоением
    double sum_half = 0.0;
    double step = 12.0 / n;
    for (int i = 0; i < n; i++) {
        double x = (i + 0.5) * step;
        sum_half += (12.0 - x);
    }
    double half_area = sum_half * step;
    double double_area = 2.0 * half_area;
    cout << "4. Через правую половину: S = " << double_area << "\n";
    cout << "\nОтвет: Площадь заштрихованной фигуры = " << analytic << "\n";
    
    return 0;
}
