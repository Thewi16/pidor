#include <iostream>
#include <cmath>
using namespace std;

int main() {
    double x, y;
    cin >> x >> y;

    if (y > 12 || y < fabs(x)) {
        cout << "Нет" << endl;
    } else if (y == 12 || y == fabs(x)) {
        cout << "На границе" << endl;
    } else {
        cout << "Да" << endl;
    }

    return 0;
}
